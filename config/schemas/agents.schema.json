{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://affiliate-ops.local/schemas/agents.schema.json",
  "title": "Agent Runtime Configuration",
  "type": "object",
  "required": ["version", "agents"],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "agents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "enabled", "concurrency", "timeoutSeconds"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "enabled": { "type": "boolean" },
          "concurrency": { "type": "integer", "minimum": 1, "maximum": 10 },
          "timeoutSeconds": { "type": "integer", "minimum": 1, "maximum": 7200 }
        }
      }
    }
  }
}
