{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "office-map.schema.json",
  "title": "Office map",
  "type": "object",
  "required": ["id", "gridSize", "width", "height", "zones", "workstations", "pois", "routes", "navigation", "objects"],
  "properties": {
    "id": { "type": "string" },
    "gridSize": { "type": "integer", "minimum": 8 },
    "width": { "type": "number", "exclusiveMinimum": 0 },
    "height": { "type": "number", "exclusiveMinimum": 0 },
    "zones": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "label", "x", "y", "width", "height"],
        "properties": {
          "id": { "type": "string" },
          "label": { "type": "string" },
          "x": { "type": "number" },
          "y": { "type": "number" },
          "width": { "type": "number", "exclusiveMinimum": 0 },
          "height": { "type": "number", "exclusiveMinimum": 0 }
        },
        "additionalProperties": false
      }
    },
    "pois": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "activity", "point", "slots", "navNode", "capacity", "duration", "label"],
        "properties": {
          "id": { "type": "string" },
          "activity": { "type": "string" },
          "point": { "$ref": "#/$defs/point" },
          "slots": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "#/$defs/point" }
          },
          "navNode": { "type": "string" },
          "capacity": { "type": "integer", "minimum": 1 },
          "duration": { "type": "number", "exclusiveMinimum": 0 },
          "label": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "routes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "x", "y", "width", "height"],
        "properties": {
          "id": { "type": "string" },
          "x": { "type": "number" },
          "y": { "type": "number" },
          "width": { "type": "number", "exclusiveMinimum": 0 },
          "height": { "type": "number", "exclusiveMinimum": 0 }
        },
        "additionalProperties": false
      }
    },
    "navigation": {
      "type": "object",
      "required": ["nodes", "edges"],
      "properties": {
        "nodes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "x", "y"],
            "properties": {
              "id": { "type": "string" },
              "x": { "type": "number" },
              "y": { "type": "number" }
            },
            "additionalProperties": false
          }
        },
        "edges": {
          "type": "array",
          "items": {
            "type": "array",
            "prefixItems": [{ "type": "string" }, { "type": "string" }],
            "minItems": 2,
            "maxItems": 2
          }
        }
      },
      "additionalProperties": false
    },
    "objects": {
      "type": "array",
      "items": { "$ref": "#/$defs/object" }
    },
    "workstations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "zone", "desk", "chair", "x", "y", "facing", "seat", "approach", "stand", "navNode", "collision"],
        "properties": {
          "id": { "type": "string" },
          "zone": { "type": "string" },
          "desk": { "type": "string" },
          "chair": { "type": "string" },
          "x": { "type": "number" },
          "y": { "type": "number" },
          "facing": { "enum": ["up", "down", "left", "right"] },
          "seat": { "$ref": "#/$defs/point" },
          "approach": { "$ref": "#/$defs/point" },
          "stand": { "$ref": "#/$defs/point" },
          "navNode": { "type": "string" },
          "collision": { "$ref": "#/$defs/rectangle" }
        },
        "additionalProperties": false
      }
    }
  },
  "$defs": {
    "point": {
      "type": "object",
      "required": ["x", "y"],
      "properties": { "x": { "type": "number" }, "y": { "type": "number" } },
      "additionalProperties": false
    },
    "rectangle": {
      "type": "object",
      "required": ["x", "y", "width", "height"],
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" },
        "width": { "type": "number", "exclusiveMinimum": 0 },
        "height": { "type": "number", "exclusiveMinimum": 0 }
      },
      "additionalProperties": false
    },
    "object": {
      "type": "object",
      "required": ["id", "asset", "layer", "anchor"],
      "oneOf": [
        { "required": ["x", "y"] },
        { "required": ["parentId", "slot"] }
      ],
      "properties": {
        "id": { "type": "string" },
        "asset": { "type": "string" },
        "x": { "type": "number" },
        "y": { "type": "number" },
        "parentId": { "type": "string" },
        "slot": { "type": "string" },
        "layer": { "enum": ["wall", "furniture", "equipment", "decor"] },
        "anchor": { "enum": ["center", "bottom-center", "wall-top", "wall-right"] }
      },
      "additionalProperties": false
    }
  }
}
