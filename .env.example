# Shared
APP_ENV=development
LOG_LEVEL=info
APP_TIMEZONE=Asia/Bangkok
APP_WORKSPACE_ID=pilot-workspace
APP_DATA_ROOT=./runtime-data
APP_DATABASE_FILE=./runtime-data/database/affiliate-ops.sqlite
GOOGLE_SPREADSHEET_ID=1iIF2Pb9THDMLIJz66JgjxKIW6f0j_b-f_2aB2jhZo1s
TEAM_BRAIN_PROVIDER=mock

# Cloudflare control plane (configure through Wrangler secrets in production)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_D1_DATABASE_ID=
# Optional later. Local/Oracle filesystem is the current object store.
CLOUDFLARE_R2_BUCKET=
RUNNER_CONTROL_TOKEN=

# Discord (never expose the bot token to the browser)
DISCORD_APPLICATION_ID=
DISCORD_PUBLIC_KEY=
DISCORD_BOT_TOKEN=

# Meta Graph API
META_APP_ID=
META_APP_SECRET=
META_PAGE_ACCESS_TOKEN=

# Runner-local opaque locations; do not place credentials in these values
RUNNER_ID=local-pilot-01
RUNNER_PROFILE_ROOT=
RUNNER_ARTIFACT_ROOT=
RUNNER_ENCRYPTION_KEY_FILE=

# Feature flags default to safe/off
ENABLE_SHOPEE_DISCOVERY=false
ENABLE_SHOPEE_LINK_CREATION=false
ENABLE_GEMINI_BROWSER=false
ENABLE_FLOW_BROWSER=false
ENABLE_META_PUBLISHING=false
ENABLE_BROWSER_PUBLISHING_FALLBACK=false
