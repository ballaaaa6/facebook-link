[Unit]
Description=Affiliate Operations Automation Runner
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=affiliate-runner
Group=affiliate-runner
WorkingDirectory=/opt/affiliate-ops
EnvironmentFile=/etc/affiliate-ops/runner.env
ExecStart=/usr/bin/npm run start --workspace @affiliate-ops/automation-runner
Restart=on-failure
RestartSec=10
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ReadWritePaths=/var/lib/affiliate-ops /var/log/affiliate-ops

[Install]
WantedBy=multi-user.target
