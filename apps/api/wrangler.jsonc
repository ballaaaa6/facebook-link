{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "affiliate-ops-api",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-23",
  "observability": { "enabled": true },
  "vars": {
    "APP_ENV": "development",
    "BRAIN_PROVIDER": "workers-ai",
    "BRAIN_MODEL": "@cf/zai-org/glm-4.7-flash"
  },
  "ai": {
    "binding": "AI"
  }
}
